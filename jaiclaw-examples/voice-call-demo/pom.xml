<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.jaiclaw</groupId>
        <artifactId>jaiclaw-examples</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>jaiclaw-example-voice-call-demo</artifactId>
    <name>JaiClaw :: Examples :: Voice Call Demo</name>
    <description>Telephony demo — outbound appointment reminder calls and inbound customer service via Twilio</description>

    <dependencies>
        <!-- Gateway starter (auto-config + gateway library + web) -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-starter-gateway</artifactId>
            <type>pom</type>
        </dependency>

        <!-- Voice call extension (telephony, webhook, media streaming, MCP tools) -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-voice-call</artifactId>
        </dependency>

        <!-- Voice extension (TTS/STT providers) -->
        <dependency>
            <groupId>io.jaiclaw</groupId>
            <artifactId>jaiclaw-voice</artifactId>
        </dependency>

        <!-- AI provider -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-anthropic</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-minimax</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>io.jaiclaw</groupId>
                <artifactId>jaiclaw-maven-plugin</artifactId>
                <version>${project.version}</version>
                <executions>
                    <execution>
                        <goals><goal>analyze</goal></goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
