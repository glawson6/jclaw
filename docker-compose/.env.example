# LLM Provider — set AI_PROVIDER to match your API key (anthropic, openai, or ollama)
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local LLM) — set AI_PROVIDER=ollama and OLLAMA_ENABLED=true
# To start Ollama:  docker compose --profile ollama up -d
# Then pull a model: docker compose --profile ollama exec ollama ollama pull llama3.2
OLLAMA_ENABLED=false

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Slack (optional — set APP_TOKEN for Socket Mode, or SIGNING_SECRET for webhook mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Discord (optional — set USE_GATEWAY=true for Gateway WebSocket mode)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_USE_GATEWAY=

# Port overrides
GATEWAY_PORT=8080
OLLAMA_PORT=11434
