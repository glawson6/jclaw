    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Aligned with Embabel 0.3.4 compatibility -->
        <spring-boot.version>3.5.6</spring-boot.version>
        <spring-ai.version>1.1.3</spring-ai.version>
        <embabel-agent.version>0.3.4</embabel-agent.version>
        <spring-shell.version>3.4.0</spring-shell.version>

        <!-- Testing -->
        <spock.version>2.4-M4-groovy-4.0</spock.version>
        <groovy.version>4.0.24</groovy.version>
        <gmavenplus-plugin.version>4.0.1</gmavenplus-plugin.version>

        <!-- Third-party libraries -->
        <github-api.version>1.330</github-api.version>

        <!-- Plugins -->
        <maven-compiler-plugin.version>3.13.0</maven-compiler-plugin.version>
        <maven-surefire-plugin.version>3.5.2</maven-surefire-plugin.version>
        <jkube.version>1.17.0</jkube.version>
    </properties>

