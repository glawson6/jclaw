    <name>JClaw</name>
    <description>Java/Spring AI personal assistant — embeddable agent runtime with tools, skills, and plugins</description>
    <url>https://github.com/jclaw/jclaw</url>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
