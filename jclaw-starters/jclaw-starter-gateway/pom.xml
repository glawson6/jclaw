<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.jclaw</groupId>
        <artifactId>jclaw-starters</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>jclaw-starter-gateway</artifactId>
    <packaging>pom</packaging>
    <name>JClaw :: Starter :: Gateway</name>
    <description>JClaw starter for REST + WebSocket gateway with all channel adapters</description>

    <dependencies>
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-spring-boot-starter</artifactId>
        </dependency>

        <!-- Gateway library (REST controller, WebSocket, webhook dispatcher) -->
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-gateway</artifactId>
        </dependency>

        <!-- All channel adapters -->
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-channel-telegram</artifactId>
        </dependency>
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-channel-slack</artifactId>
        </dependency>
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-channel-discord</artifactId>
        </dependency>
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-channel-email</artifactId>
        </dependency>
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-channel-sms</artifactId>
        </dependency>
        <dependency>
            <groupId>io.jclaw</groupId>
            <artifactId>jclaw-channel-signal</artifactId>
        </dependency>

        <!-- Embedded web server -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>
</project>
