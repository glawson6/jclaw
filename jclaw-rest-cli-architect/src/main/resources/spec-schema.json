{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JRestCLI Project Spec",
  "description": "Input specification for generating a Spring Shell CLI project that wraps a REST API",
  "type": "object",
  "required": ["name", "api"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Short name used as CLI command prefix and module suffix (e.g. 'acme')"
    },
    "mode": {
      "type": "string",
      "enum": ["JCLAW_SUBMODULE", "EXTERNAL_SUBMODULE", "STANDALONE", "JBANG"],
      "default": "STANDALONE",
      "description": "Project structure mode"
    },
    "outputDir": {
      "type": "string",
      "description": "Directory where the project should be generated"
    },
    "groupId": {
      "type": "string",
      "description": "Maven groupId for the generated project (e.g. 'com.example')"
    },
    "packageName": {
      "type": "string",
      "description": "Java package name (e.g. 'com.example.cli.acme')"
    },
    "outputFormat": {
      "type": "string",
      "enum": ["json", "table", "both"],
      "default": "both",
      "description": "How API responses should be formatted in CLI output"
    },
    "api": {
      "type": "object",
      "required": [],
      "properties": {
        "title": {
          "type": "string",
          "description": "Display name for the API"
        },
        "baseUrl": {
          "type": "string",
          "description": "Base URL for the API (e.g. 'https://api.acme.com/v1')"
        },
        "openapiSpec": {
          "type": "string",
          "description": "URL or file path to an OpenAPI/Swagger spec (JSON). When provided, endpoints and auth are auto-extracted."
        }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "header", "basic", "oauth2"],
          "default": "none"
        },
        "headerName": {
          "type": "string",
          "description": "Header name for header auth (e.g. 'Authorization', 'X-API-Key')"
        },
        "headerValuePrefix": {
          "type": "string",
          "description": "Prefix before the token value (e.g. 'Bearer ')"
        },
        "envVar": {
          "type": "string",
          "description": "Environment variable holding the API key/token"
        },
        "usernameEnv": {
          "type": "string",
          "description": "Env var for basic auth username"
        },
        "passwordEnv": {
          "type": "string",
          "description": "Env var for basic auth password"
        },
        "tokenUrl": {
          "type": "string",
          "description": "OAuth2 token endpoint URL"
        },
        "clientIdEnv": {
          "type": "string",
          "description": "Env var for OAuth2 client ID"
        },
        "clientSecretEnv": {
          "type": "string",
          "description": "Env var for OAuth2 client secret"
        },
        "scopes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "OAuth2 scopes"
        }
      }
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path"],
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"]
          },
          "path": {
            "type": "string",
            "description": "URL path template (e.g. '/users/{id}')"
          },
          "operationId": {
            "type": "string",
            "description": "Unique operation identifier"
          },
          "summary": {
            "type": "string",
            "description": "Human-readable description"
          },
          "commandKey": {
            "type": "string",
            "description": "CLI command suffix (e.g. 'list-users')"
          },
          "tag": {
            "type": "string",
            "description": "Grouping tag"
          },
          "params": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string", "default": "string" },
                "in": { "type": "string", "enum": ["path", "query", "header", "body"], "default": "query" },
                "required": { "type": "boolean", "default": false }
              }
            }
          }
        }
      }
    }
  }
}
